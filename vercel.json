{
  "cleanUrls": true,
  "installCommand": null,
  "buildCommand": null,
  "outputDirectory": "./",
  "headers": [
    {
      "source": "/(.*)\\.(mind|glb|gltf|bin|mp3)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
