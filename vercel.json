{
  "cleanUrls": true,
  "installCommand": "echo 'Skipping npm install for static site'",
  "buildCommand": "echo 'Deploying static files'",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)\\.(mind|glb|gltf|bin|mp3)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
